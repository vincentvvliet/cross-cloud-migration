{
  "BaseQueue": {
    "import": "import BaseQueue.* from \"../systems/queue/baseQueue\"",
    "state": ["queue", "inflight", "history", "delivered"],
    "type": "queue",
    "actions": {
      "enqueue": { "arg_type": "msg", "composite": true, "input": "input"},
      "deliver": { "arg_type": "msg", "composite": true, "input": "getHead(queue)"}
    },
    "init": "initQueue"
  }, 

  "BaseKV": {
    "import": "import BaseKV.* from \"../systems/kv/baseKV\"",
    "state": ["kv", "lastWrite", "visibleReplicas"],
    "type": "kv",
    "actions": {
      "sync": { "arg_type": "sync", "composite": true, "input": "replica, dst"}
    },
    "init": "initKV"
  },

  "KVQueue": {
    "import": "import KVQueue.* from \"../systems/compositions/kvQueue\"",
    "state": ["processed"],
    "type": "composition",
    "actions": {
      "process": { "arg_type": "msg_replica", "composite": false, "input": "getHead(inflight), replica"}
    },
    "init": "initComposition"
  },

  "Redis": {
    "import": "import Redis.* from \"../systems/queue/redis\"",
    "state": ["queue", "inflight", "history", "delivered"],
    "type": "queue",
    "actions": {
      "enqueue": { "arg_type": "msg", "composite": true, "input": "input"},
      "deliver": { "arg_type": "msg", "composite": true, "input": "getHead(queue)"},
      "crash": { "arg_type": "crash", "composite": true, "input": null}
    },
    "init": "initQueue"
  }
}
